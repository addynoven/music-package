# SDK testing/playground env. Loaded via Node's native --env-file flag.
#
#   pnpm exec tsx --env-file=.env playground/<script>.ts
#
# Copy this file to .env (gitignored) and fill in the keys you need.

# ── YouTube ─────────────────────────────────────────────────────────────────
# Data API v3 key — switches the SDK from InnerTube (anonymous) to the
# official Data API for search + metadata. Get one at:
#   https://console.cloud.google.com → YouTube Data API v3 → Credentials
YT_API_KEY=

# Path to a Netscape cookies.txt — gives yt-dlp/InnerTube a logged-in YT
# session (higher stream limits, fewer 429s).
#   yt-dlp --cookies-from-browser chrome --cookies cookies.txt --skip-download https://youtube.com
COOKIES_PATH=

# ── YouTube Music locale ────────────────────────────────────────────────────
# Affects search ranking, home feed, charts. Optional.
# YT_LANGUAGE=en   # BCP-47 (en, hi, ja, ta, ...)
# YT_LOCATION=US   # ISO 3166-1 alpha-2 (US, IN, JP, ...)

# ── Audio identification ────────────────────────────────────────────────────
# AcoustID free key for fingerprint-based identify():
#   https://acoustid.org/login
ACOUSTID_API_KEY=

# Optional Shazam fallback — install songrec, then point here:
# SONGREC_BIN=/usr/bin/songrec

# ── Network ─────────────────────────────────────────────────────────────────
# HTTP/HTTPS proxy for all outbound SDK traffic (testing under VPN-like setups)
# PROXY=http://user:pass@proxy.example.com:8080

# ── Diagnostics ─────────────────────────────────────────────────────────────
# silent | error | warn | info | debug
LOG_LEVEL=info

# ── Test runner gates ───────────────────────────────────────────────────────
# RUN_INTEGRATION=1   # enables tests/integration/*  (mocked + isolated)
# RUN_LIVE=1          # enables tests/integration/live*.ts (hits real APIs)
