{
  "name": "musicstream-sdk",
  "version": "1.0.1",
  "description": "Unified music SDK for YouTube Music and JioSaavn — search, stream, lyrics, podcasts, download. No API keys required.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit --reporter=verbose",
    "test:watch": "vitest tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:integration": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:all": "vitest run --reporter=verbose",
    "play": "tsx playground/download-test.ts"
  },
  "keywords": [
    "youtube-music",
    "jiosaavn",
    "music",
    "sdk",
    "streaming",
    "audio",
    "search",
    "lyrics",
    "podcast",
    "download",
    "youtube",
    "music-api",
    "music-streaming",
    "innertube",
    "waveform",
    "fingerprint",
    "no-api-key",
    "typescript"
  ],
  "author": "capitalcurv8",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@unimusic/chromaprint": "^0.1.4",
    "node-forge": "^1.4.0",
    "rss-parser": "^3.13.0",
    "youtubei.js": "^17.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^3.2.4",
    "pnpm": "^10.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
